{
    "name": "Remote Polaris",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    
    // Configure tool-specific properties
    "customizations": {
        "vscode": {
            "settings": {
                // Point VS Code's Python extension to the Conda environment
                "python.defaultInterpreterPath": "/opt/conda/bin/python",
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "google.geminicodeassist",
            ]
        }
    },
    "postCreateCommand": "bash .devcontainer/post-install.sh",
    // Run as the standard non-root user provided by the base image
    "remoteUser": "root",
    "mounts": [
        "source=/home/jhahnewald/datasets,target=/workspaces/datasets,type=bind,consistency=cached"
    ],
    "runArgs": [
        "--shm-size", "100G",
        "--gpus", "\"device=02,03\""
    ]    
}
